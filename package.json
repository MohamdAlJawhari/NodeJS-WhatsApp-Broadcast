{
  "name": "broadcast-sender",
  "version": "1.1.5",
  "description": "Internal WhatsApp and Telegram broadcast sender desktop app",
  "productName": "Broadcast Sender",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "electron": "electron .",
    "cli": "node src/app.js",
    "test": "node --test tests/*.test.js",
    "build:win": "electron-builder --win --x64 --publish never"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@wppconnect-team/wppconnect": "^1.8.12",
    "csv-writer": "^1.6.0",
    "dotenv": "^17.4.2",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "libphonenumber-js": "^1.12.43",
    "puppeteer": "^24.43.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "telegram": "^2.26.22",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "electron": "^42.0.1",
    "electron-builder": "^24.13.3",
    "rcedit": "^5.0.2"
  },
  "build": {
    "appId": "com.internal.whatsapp-broadcast-sender",
    "productName": "Broadcast Sender",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "MohamdAlJawhari",
        "repo": "NodeJS-WhatsApp-Broadcast"
      }
    ],
    "files": [
      "package.json",
      "build/icon.ico",
      "build/icon.svg",
      "electron/**/*",
      "src/**/*",
      "settings.json",
      "!AI_PROJECT_CONTEXT.md",
      "!README.md",
      "!data{,/**/*}",
      "!media{,/**/*}",
      "!logs{,/**/*}",
      "!tokens{,/**/*}",
      "!.env",
      "!.env.*",
      "!.git{,/**/*}",
      "!node_modules/.cache{,/**/*}",
      "!release{,/**/*}"
    ],
    "asar": false,
    "afterPack": "scripts/afterPack.cjs",
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false,
      "artifactName": "Broadcast-Sender-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Broadcast Sender"
    }
  }
}
