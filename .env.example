# Copy this file to .env for local development.
# The packaged Windows app does not include .env. Runtime settings for the
# packaged app are stored in %APPDATA%\WhatsApp Broadcast Sender\settings.json.

# WhatsApp/WPPConnect session name.
SESSION_NAME=employee-session

# Telegram user-account login through GramJS.
# Get these from https://my.telegram.org/apps.
# Do not commit real values.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_NAME=telegram-session

# CLI-only defaults. The Electron GUI lets the user choose contacts/media.
CONTACTS_FILE=./data/contacts.xlsx
MEDIA_FILE=

# Sending controls, in milliseconds.
MESSAGE_DELAY_MIN=10000
MESSAGE_DELAY_MAX=20000
BATCH_SIZE=5
BATCH_PAUSE=30000
MEDIA_RETRY_ATTEMPTS=3
MEDIA_RETRY_DELAY=15000

# Accepted contact phone columns include "phone" and "NUMBERS".
PHONE_COLUMN=phone
